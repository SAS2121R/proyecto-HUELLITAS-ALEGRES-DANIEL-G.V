# ============================================
# .gitignore — Huellitas Alegres (Django)
# ============================================

# Base de datos (NUNCA subir)
*.sqlite3
*.sqlite3-journal
*.sqlite
*.sqlite-journal
*.db
db.sqlite3

# Entorno virtual y Python
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/

# Archivos de la IA y Contexto (NO subir)
openspec/
.atl/
.engram/

# Configuración de entorno y SECRETOS
.env
.env.*
*.key
*.pem

# Configuraciones de editor y sistema
.vscode/
.idea/
.DS_Store
Thumbs.db

# Archivos estáticos recolectados (se regeneran con collectstatic)
staticfiles/
/static/
**/static/admin/
**/static/rest_framework/

# Media files (subidos por usuarios)
media/
**/media/

# Artefactos de Testsprite (no son parte del proyecto)
testsprite_tests/
tests_sprite_tests_placeholder.txt
TestSprite-Reporte-Frontend.zip

# Logs
*.log
*.pot

# Script SQL de backup
script_db.sql